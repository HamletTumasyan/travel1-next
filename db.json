  "homepage_details": [
    {
      "id": 1,
      "lang": "en",
      "description": "Before organizing the event, it is important to clearly define its purpose. Then, a detailed budget should be prepared, including all major expenses. In addition, it is advisable to have a contingency fund in case of unexpected costs or changes."
    },
    {
      "id": 1,
      "lang": "am",
      "description": "Նախքան միջոցառման կազմակերպումը, անհրաժեշտ է կազմել մանրամասն բյուջե, որտեղ ներառված կլինեն բոլոր հիմնական ծախսերը։ Բացի դրանից, ցանկալի է ունենալ պահուստային ֆոնդ՝ անսպասելի ծախսերի կամ փոփոխությունների դեպքում"
    }
  ],
